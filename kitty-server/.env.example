# Kitty Server 环境变量配置

# OpenClaw LLM 服务配置
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=

# 火山引擎 ASR 配置
VOLC_ASR_APP_ID=
VOLC_ASR_TOKEN=
VOLC_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# 火山引擎 TTS 配置
VOLC_TTS_APP_ID=
VOLC_TTS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts

# 模型 Provider API Keys
DEEPSEEK_API_KEY=
BAILIAN_API_KEY=
QIANFAN_API_KEY=
LITELLM_API_KEY=

# Agent 默认模型（用户未指定时使用）
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# LangGraph Checkpoint 存储路径
CHECKPOINT_DB_PATH=./data/checkpoints.sqlite
