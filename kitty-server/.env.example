# Kitty Server 环境变量配置

# OpenClaw LLM 服务配置
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=your-openclaw-token

# 火山引擎 ASR 配置
VOLC_ASR_APP_ID=your-asr-app-id
VOLC_ASR_TOKEN=your-asr-token
VOLC_ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# 火山引擎 TTS 配置
VOLC_TTS_APP_ID=your-tts-app-id
VOLC_TTS_TOKEN=your-tts-token
VOLC_TTS_CLUSTER=volcano_tts